{
  "name": "ifs-bruno",
  "version": "1.2.0",
  "description": "Import IFS OpenAPI endpoints into Bruno collections",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmeza44/ifs-bruno.git"
  },
  "homepage": "https://github.com/jmeza44/ifs-bruno#readme",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ifs-bruno": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "release:patch": "npm version patch && git push origin main --follow-tags",
    "release:minor": "npm version minor && git push origin main --follow-tags",
    "release:major": "npm version major && git push origin main --follow-tags"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "i18next": "^26.0.6",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.8",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
